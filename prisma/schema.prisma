generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model basket {
  id      BigInt @unique(map: "id_basket") @default(autoincrement()) @db.UnsignedBigInt
  game_id BigInt @db.UnsignedBigInt
  user_id BigInt @db.UnsignedBigInt
  games   games  @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "basket_ibfk_1")
  users   users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "basket_ibfk_2")

  @@unique([user_id, game_id], map: "uq_basket_user_game")
  @@index([game_id], map: "id_game")
  @@index([user_id], map: "id_user")
}

model favourites {
  id      BigInt  @unique(map: "id_favourites") @default(autoincrement()) @db.UnsignedBigInt
  user_id BigInt? @db.UnsignedBigInt
  game_id BigInt? @db.UnsignedBigInt
  users   users?  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "favourites_ibfk_1")
  games   games?  @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "favourites_ibfk_2")

  @@index([game_id], map: "id_games")
  @@index([user_id], map: "id_user")
}

model game_tags {
  id      BigInt @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  game_id BigInt @db.UnsignedBigInt
  tags_id BigInt @db.UnsignedBigInt
  games   games  @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "game_tags_ibfk_1")
  tags    tags   @relation(fields: [tags_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "game_tags_ibfk_2")

  @@unique([game_id, tags_id], map: "uq_game_tags")
  @@index([game_id], map: "game_tags_ibfk_1")
  @@index([tags_id], map: "game_tags_ibfk_2")
}

model games {
  id           BigInt        @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  title        String        @unique(map: "title") @db.VarChar(255)
  description  String        @db.Text
  price        Decimal       @db.Decimal(10, 2)
  release_date DateTime?     @db.Date
  created_at   DateTime      @default(now()) @db.Timestamp(0)
  updated_at   DateTime      @default(now()) @db.Timestamp(0)
  basket       basket[]
  favourites   favourites[]
  game_images  game_images[]
  game_tags    game_tags[]
  game_videos  game_videos[]
  order_items  order_items[]
  user_games   user_games[]
}

model tags {
  id         BigInt      @unique(map: "id_tags") @default(autoincrement()) @db.UnsignedBigInt
  name       String      @unique(map: "name")
  created_at DateTime    @default(now()) @db.Timestamp(0)
  type_id    BigInt      @default(1) @db.UnsignedBigInt
  game_tags  game_tags[]
  tag_types  tag_types   @relation(fields: [type_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tags_ibfk_1")

  @@index([type_id], map: "type_id")
}

model users {
  id             BigInt           @unique(map: "id_user") @default(autoincrement()) @db.UnsignedBigInt
  name           String           @db.VarChar(20)
  email          String           @unique(map: "email") @db.VarChar(255)
  password_hash  String?          @db.Text
  role_id        BigInt           @default(2) @db.UnsignedBigInt
  avatar_url     String?          @db.Text
  created_at     DateTime         @default(now()) @db.Timestamp(0)
  basket         basket[]
  favourites     favourites[]
  orders         orders[]
  user_games     user_games[]
  user_providers user_providers[]
  user_sessions  user_sessions[]
  roles          roles            @relation(fields: [role_id], references: [id], onDelete: Cascade, map: "users_ibfk_1")

  @@index([role_id], map: "role_id")
}

model game_images {
  id         BigInt   @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  url        String   @db.Text
  alt        String   @db.VarChar(100)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamp(0)
  game_id    BigInt   @db.UnsignedBigInt
  games      games    @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "game_images_ibfk_1")

  @@index([game_id], map: "game_id")
}

model game_videos {
  id         BigInt   @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  url        String   @db.Text
  title      String   @db.VarChar(255)
  duration   Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  game_id    BigInt   @db.UnsignedBigInt
  games      games    @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "game_videos_ibfk_1")

  @@index([game_id], map: "game_id")
}

model tag_types {
  id         BigInt @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  name       String @db.VarChar(50)
  sort_order Int    @db.TinyInt
  tags       tags[]
}

model providers {
  id             BigInt           @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  code           String           @unique(map: "code") @db.VarChar(50)
  name           String           @db.VarChar(100)
  is_active      Boolean          @default(true)
  created_at     DateTime         @default(now()) @db.Timestamp(0)
  user_providers user_providers[]
}

model roles {
  id          BigInt   @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  name        String   @unique(map: "name") @db.VarChar(50)
  description String?  @db.VarChar(255)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  users       users[]
}

model user_providers {
  id               BigInt    @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  user_id          BigInt    @db.UnsignedBigInt
  provider_id      BigInt    @db.UnsignedBigInt
  provider_user_id String    @unique(map: "provider_user_id") @db.VarChar(255)
  provider_email   String?   @db.VarChar(255)
  created_at       DateTime  @default(now()) @db.Timestamp(0)
  updated_at       DateTime? @default(now()) @db.Timestamp(0)
  providers        providers @relation(fields: [provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_providers_ibfk_1")
  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_providers_ibfk_2")

  @@index([provider_id], map: "provider_id")
  @@index([user_id], map: "user_id")
}

model user_sessions {
  id                  BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id             BigInt    @db.UnsignedBigInt
  refresh_token_hash  String    @db.VarChar(255)
  user_agent          String?   @db.VarChar(512)
  ip                  String?   @db.VarChar(45)
  expires_at          DateTime  @db.DateTime(0)
  absolute_expires_at DateTime  @db.DateTime(0)
  created_at          DateTime  @default(now()) @db.DateTime(0)
  updated_at          DateTime  @default(now()) @db.DateTime(0)
  revoked_at          DateTime? @db.DateTime(0)
  users               users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_sessions_user")

  @@index([expires_at], map: "idx_user_sessions_expires_at")
  @@index([revoked_at], map: "idx_user_sessions_revoked_at")
  @@index([user_id], map: "idx_user_sessions_user_id")
}

model order_items {
  id             BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  order_id       BigInt      @db.UnsignedBigInt
  game_id        BigInt      @db.UnsignedBigInt
  title_snapshot String      @db.VarChar(255)
  price_snapshot Decimal     @db.Decimal(10, 2)
  created_at     DateTime    @default(now()) @db.DateTime(0)
  games          games       @relation(fields: [game_id], references: [id], map: "fk_order_items_game")
  orders         orders      @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "fk_order_items_order")
  user_games     user_games?

  @@unique([order_id, game_id], map: "uq_order_items_order_game")
  @@index([game_id], map: "idx_order_items_game_id")
}

model orders {
  id           BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt        @db.UnsignedBigInt
  status       orders_status @default(waiting_for_payment)
  source       orders_source
  currency     String        @default("RUB") @db.Char(3)
  total_amount Decimal       @db.Decimal(10, 2)
  paid_at      DateTime?     @db.DateTime(0)
  canceled_at  DateTime?     @db.DateTime(0)
  created_at   DateTime      @default(now()) @db.DateTime(0)
  updated_at   DateTime      @default(now()) @db.DateTime(0)
  order_items  order_items[]
  users        users         @relation(fields: [user_id], references: [id], map: "fk_orders_user")
  payments     payments[]

  @@index([status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user_id")
}

model payment_webhook_events {
  id                 BigInt                          @id @default(autoincrement()) @db.UnsignedBigInt
  provider           payment_webhook_events_provider @default(yookassa)
  event_type         String                          @db.VarChar(100)
  external_object_id String                          @db.VarChar(64)
  payload            Json
  is_processed       Boolean                         @default(false)
  processed_at       DateTime?                       @db.DateTime(0)
  created_at         DateTime                        @default(now()) @db.DateTime(0)

  @@unique([provider, event_type, external_object_id], map: "uq_payment_webhook_event")
  @@index([is_processed], map: "idx_payment_webhook_processed")
}

model payments {
  id                  BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  order_id            BigInt            @db.UnsignedBigInt
  provider            payments_provider @default(yookassa)
  external_payment_id String?           @unique(map: "uq_payments_external_payment_id") @db.VarChar(64)
  idempotence_key     String            @unique(map: "uq_payments_idempotence_key") @db.Char(36)
  status              payments_status   @default(pending)
  amount              Decimal           @db.Decimal(10, 2)
  currency            String            @default("RUB") @db.Char(3)
  confirmation_url    String?           @db.Text
  paid_at             DateTime?         @db.DateTime(0)
  canceled_at         DateTime?         @db.DateTime(0)
  raw_payload         Json?
  created_at          DateTime          @default(now()) @db.DateTime(0)
  updated_at          DateTime          @default(now()) @db.DateTime(0)
  orders              orders            @relation(fields: [order_id], references: [id], onDelete: Cascade, map: "fk_payments_order")

  @@index([order_id], map: "idx_payments_order_id")
  @@index([status], map: "idx_payments_status")
}

model user_games {
  id            BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  user_id       BigInt            @db.UnsignedBigInt
  game_id       BigInt            @db.UnsignedBigInt
  order_item_id BigInt            @unique(map: "uq_user_games_order_item") @db.UnsignedBigInt
  status        user_games_status @default(active)
  granted_at    DateTime          @default(now()) @db.DateTime(0)
  revoked_at    DateTime?         @db.DateTime(0)
  games         games             @relation(fields: [game_id], references: [id], map: "fk_user_games_game")
  order_items   order_items       @relation(fields: [order_item_id], references: [id], map: "fk_user_games_order_item")
  users         users             @relation(fields: [user_id], references: [id], map: "fk_user_games_user")

  @@unique([user_id, game_id], map: "uq_user_games_user_game")
  @@index([game_id], map: "idx_user_games_game_id")
  @@index([user_id], map: "idx_user_games_user_id")
}

enum payment_webhook_events_provider {
  yookassa
}

enum orders_status {
  waiting_for_payment
  paid
  canceled
  failed
}

enum payments_provider {
  yookassa
}

enum orders_source {
  basket
}

enum user_games_status {
  active
  revoked
}

enum payments_status {
  pending
  waiting_for_capture
  succeeded
  canceled
  failed
}
