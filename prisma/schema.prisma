generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model basket {
  id_basket BigInt @unique(map: "id_basket") @default(autoincrement()) @db.UnsignedBigInt
  id_game   BigInt @db.UnsignedBigInt
  id_user   BigInt @db.UnsignedBigInt
  games     games  @relation(fields: [id_game], references: [id_game], onDelete: Cascade, onUpdate: NoAction, map: "basket_ibfk_1")
  users     users  @relation(fields: [id_user], references: [id_user], onDelete: Cascade, onUpdate: NoAction, map: "basket_ibfk_2")

  @@index([id_game], map: "id_game")
  @@index([id_user], map: "id_user")
}

model favourites {
  id_favourites BigInt  @unique(map: "id_favourites") @default(autoincrement()) @db.UnsignedBigInt
  id_user       BigInt? @db.UnsignedBigInt
  id_games      BigInt? @db.UnsignedBigInt
  users         users?  @relation(fields: [id_user], references: [id_user], onDelete: Cascade, onUpdate: NoAction, map: "favourites_ibfk_1")
  games         games?  @relation(fields: [id_games], references: [id_game], onDelete: Cascade, onUpdate: NoAction, map: "favourites_ibfk_2")

  @@index([id_games], map: "id_games")
  @@index([id_user], map: "id_user")
}

model game_tags {
  id      BigInt @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  id_game BigInt @db.UnsignedBigInt
  id_tags BigInt @db.UnsignedBigInt
  games   games  @relation(fields: [id_game], references: [id_game], onDelete: Cascade, onUpdate: Restrict, map: "game_tags_ibfk_1")
  tags    tags   @relation(fields: [id_tags], references: [id_tags], onDelete: Cascade, onUpdate: Restrict, map: "game_tags_ibfk_2")

  @@index([id_game], map: "game_tags_ibfk_1")
  @@index([id_tags], map: "game_tags_ibfk_2")
}

model games {
  id_game     BigInt        @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  title       String        @db.VarChar(255)
  description String        @db.Text
  price       Decimal       @db.Decimal(10, 2)
  created_at  DateTime      @default(now()) @db.Timestamp(0)
  updated_at  DateTime      @default(now()) @db.Timestamp(0)
  basket      basket[]
  favourites  favourites[]
  game_images game_images[]
  game_tags   game_tags[]
  game_videos game_videos[]
}

model tags {
  id_tags    BigInt      @unique(map: "id_tags") @default(autoincrement()) @db.UnsignedBigInt
  name       String      @unique(map: "name")
  created_at DateTime    @default(now()) @db.Timestamp(0)
  type_id    BigInt      @default(1) @db.UnsignedBigInt
  game_tags  game_tags[]
  tag_types  tag_types   @relation(fields: [type_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tags_ibfk_1")

  @@index([type_id], map: "type_id")
}

model users {
  id_user    BigInt       @unique(map: "id_user") @default(autoincrement()) @db.UnsignedBigInt
  name       String       @db.VarChar(20)
  login      String       @unique(map: "login") @db.VarChar(30)
  password   String       @db.Text
  role       users_role?  @default(user)
  avatar_url String       @db.Text
  created_at DateTime     @default(now()) @db.Timestamp(0)
  basket     basket[]
  favourites favourites[]
}

model game_images {
  id         BigInt   @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  url        String   @db.Text
  alt        String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(0)
  game_id    BigInt   @db.UnsignedBigInt
  games      games    @relation(fields: [game_id], references: [id_game], onDelete: Cascade, onUpdate: NoAction, map: "game_images_ibfk_1")

  @@index([game_id], map: "game_id")
}

model game_videos {
  id         BigInt   @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  url        String   @db.Text
  title      String   @db.VarChar(255)
  duration   Int
  created_at DateTime @default(now()) @db.Timestamp(0)
  game_id    BigInt   @db.UnsignedBigInt
  games      games    @relation(fields: [game_id], references: [id_game], onDelete: Cascade, onUpdate: NoAction, map: "game_videos_ibfk_1")

  @@index([game_id], map: "game_id")
}

model tag_types {
  id         BigInt @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  name       String @db.VarChar(50)
  color      String @db.VarChar(7)
  icon       String @db.VarChar(50)
  sort_order Int    @db.TinyInt
  tags       tags[]
}

enum users_role {
  user
  admin
}
